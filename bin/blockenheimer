#!/usr/bin/env -S uv run --script --quiet
# /// script
# requires-python = ">=3.12"
# dependencies = [
#     "atproto>=0.0.55",
# ]
# ///

"""
Blockenheimer: given a Bluesky post URL, add the author and everyone who
liked it to a block list.

Usage:
    blockenheimer <bsky-post-url>
    blockenheimer --dry-run <bsky-post-url>

To use this yourself, edit the CONFIGURATION section below and set the
BLOCKENHEIMER_APP_PASSWORD environment variable to an app password
(create one at Settings -> Privacy and Security -> App Passwords).
"""

import argparse
import json
import os
import re
import sys
import time
from datetime import datetime, timedelta, timezone
from pathlib import Path

from atproto import Client, models

# ----------------------------- CONFIGURATION -----------------------------

# The handle of the account that owns the block list and does the blocking.
LOGIN_HANDLE = "grids.reillywood.com"

# The record key of the block list, i.e. the last path segment of the list's
# URL. For example, if your list lives at
# https://bsky.app/profile/you.bsky.social/lists/3lpyuurzovd2s
# then the rkey is "3lpyuurzovd2s". The list must be owned by LOGIN_HANDLE.
LIST_RKEY = "3lpyuurzovd2s"

# Never block anyone followed by or following these accounts. LOGIN_HANDLE is
# always protected; add any other accounts you care about here.
PROTECTED_ACCOUNTS = ["reillywood.com"]

# Environment variable holding the app password for LOGIN_HANDLE.
APP_PASSWORD_ENV_VAR = "BLOCKENHEIMER_APP_PASSWORD"

# List members are cached on disk so repeat runs don't re-fetch a large list.
CACHE_TTL = timedelta(days=7)

# --------------------------------------------------------------------------


def cache_path() -> Path:
    base = os.environ.get("XDG_CACHE_HOME") or os.path.expanduser("~/.cache")
    return Path(base) / "blockenheimer" / "list_members.json"


def load_cached_members(list_uri: str) -> set[str] | None:
    """Return cached list members if fresh and matching list_uri, else None."""
    try:
        data = json.loads(cache_path().read_text())
        if data["list_uri"] != list_uri:
            return None
        updated_at = datetime.fromisoformat(data["updated_at"])
        if datetime.now(timezone.utc) - updated_at > CACHE_TTL:
            return None
        members = data["members"]
        if not all(isinstance(m, str) for m in members):
            return None
        return set(members)
    except (OSError, ValueError, TypeError, KeyError):
        return None


def save_cached_members(list_uri: str, members: set[str]) -> None:
    """Write list members to the cache file atomically."""
    path = cache_path()
    path.parent.mkdir(parents=True, exist_ok=True)
    payload = {
        "list_uri": list_uri,
        "updated_at": datetime.now(timezone.utc).isoformat(),
        "members": sorted(members),
    }
    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_text(json.dumps(payload))
    os.replace(tmp, path)


def parse_post_url(url: str) -> tuple[str, str]:
    """Extract (handle_or_did, rkey) from a bsky.app post URL."""
    m = re.match(r"https?://bsky\.app/profile/([^/]+)/post/([^/?#]+)", url)
    if not m:
        sys.exit(f"Error: invalid Bluesky post URL: {url}")
    return m.group(1), m.group(2)


def get_all_likes(client: Client, post_uri: str) -> list[str]:
    """Get all DIDs that liked a post, paginating through results."""
    dids: list[str] = []
    cursor: str | None = None
    while True:
        resp = client.app.bsky.feed.get_likes(
            models.AppBskyFeedGetLikes.Params(uri=post_uri, limit=100, cursor=cursor)
        )
        dids.extend(like.actor.did for like in resp.likes)
        if not resp.cursor:
            return dids
        cursor = resp.cursor


def get_existing_list_members(client: Client, list_uri: str) -> set[str]:
    """Get all DIDs already on the list."""
    members: set[str] = set()
    cursor: str | None = None
    while True:
        resp = client.app.bsky.graph.get_list(
            models.AppBskyGraphGetList.Params(list=list_uri, limit=100, cursor=cursor)
        )
        members.update(item.subject.did for item in resp.items)
        if not resp.cursor:
            return members
        cursor = resp.cursor


def get_connected_accounts(client: Client, actor: str) -> dict[str, str]:
    """Get everyone an account follows or is followed by, as {did: handle}."""
    connected: dict[str, str] = {}
    cursor: str | None = None
    while True:
        resp = client.app.bsky.graph.get_follows(
            models.AppBskyGraphGetFollows.Params(actor=actor, limit=100, cursor=cursor)
        )
        connected.update((f.did, f.handle) for f in resp.follows)
        if not resp.cursor:
            break
        cursor = resp.cursor
    cursor = None
    while True:
        resp = client.app.bsky.graph.get_followers(
            models.AppBskyGraphGetFollowers.Params(actor=actor, limit=100, cursor=cursor)
        )
        connected.update((f.did, f.handle) for f in resp.followers)
        if not resp.cursor:
            return connected
        cursor = resp.cursor


def add_to_list(client: Client, list_uri: str, did: str) -> None:
    """Add a single DID to the block list."""
    assert client.me is not None
    client.app.bsky.graph.listitem.create(
        client.me.did,
        models.AppBskyGraphListitem.Record(
            subject=did,
            list=list_uri,
            created_at=client.get_current_time_iso(),
        ),
    )


def log(msg: str) -> None:
    print(msg, file=sys.stderr)


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Add a Bluesky post's author and everyone who liked it to a block list."
    )
    parser.add_argument("post_url", help="a bsky.app post URL")
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="show who would be blocked without changing the list",
    )
    args = parser.parse_args()

    app_password = os.environ.get(APP_PASSWORD_ENV_VAR) or os.environ.get(
        "MYBLOCKENHEIMER_API_KEY"  # old name, kept for backward compatibility
    )
    if not app_password:
        sys.exit(f"Error: {APP_PASSWORD_ENV_VAR} environment variable not set")

    post_handle, post_rkey = parse_post_url(args.post_url)

    log("Logging in...")
    client = Client()
    client.login(LOGIN_HANDLE, app_password)
    assert client.me is not None

    # Resolve the post author to a DID and build the post's AT URI
    if post_handle.startswith("did:"):
        post_did = post_handle
    else:
        resolved = client.com.atproto.identity.resolve_handle(
            models.ComAtprotoIdentityResolveHandle.Params(handle=post_handle)
        )
        post_did = resolved.did
    post_uri = f"at://{post_did}/app.bsky.feed.post/{post_rkey}"

    log("Fetching likes...")
    liker_dids = get_all_likes(client, post_uri)
    log(f"Found {len(liker_dids)} likes")

    # Author + all likers, minus ourselves
    to_block = set(liker_dids)
    to_block.add(post_did)
    to_block.discard(client.me.did)

    # Don't block anyone connected to our accounts (follows or followers)
    protected: dict[str, str] = {}  # did -> handle
    for acct in [LOGIN_HANDLE, *PROTECTED_ACCOUNTS]:
        log(f"Fetching follows+followers for {acct}...")
        protected.update(get_connected_accounts(client, acct))
    skipped = to_block & protected.keys()
    if skipped:
        log(f"Skipping {len(skipped)} connected accounts:")
        for did in sorted(skipped, key=lambda d: protected[d]):
            log(f"  @{protected[did]}")
        to_block -= skipped

    # Check who's already on the list (cached for up to a week)
    list_uri = f"at://{client.me.did}/app.bsky.graph.list/{LIST_RKEY}"
    existing = load_cached_members(list_uri)
    if existing is None:
        log("Fetching existing list members...")
        existing = get_existing_list_members(client, list_uri)
        log(f"List already has {len(existing)} members")
        save_cached_members(list_uri, existing)
    else:
        log(f"Using cached list ({len(existing)} members)")

    new_dids = to_block - existing
    if not new_dids:
        log("Everyone is already on the list. Nothing to do.")
        return

    if args.dry_run:
        log(f"Dry run: would add {len(new_dids)} accounts to the block list:")
        for did in sorted(new_dids):
            log(f"  {did}")
        return

    log(f"Adding {len(new_dids)} new accounts to block list...")
    for i, did in enumerate(new_dids, 1):
        add_to_list(client, list_uri, did)
        log(f"  [{i}/{len(new_dids)}] Added {did}")
        if i < len(new_dids):
            time.sleep(0.1)

    save_cached_members(list_uri, existing | new_dids)

    already = len(to_block) - len(new_dids)
    log(f"\nDone! Added {len(new_dids)} accounts to the block list.")
    if already:
        log(f"({already} were already on the list)")


if __name__ == "__main__":
    main()
