#!/usr/bin/env bash
# Download+unzip the latest tools from RPM (Reilly's Package Manager) into ~/bin
set -euo pipefail

case "$(uname)" in
  Linux) os=linux ;;
  Darwin) os=mac ;;
  *) echo "upgrade-rpm: unsupported OS" >&2; exit 1 ;;
esac

case "$(uname -m)" in
  x86_64) arch=x64 ;;
  aarch64 | arm64) arch=arm64 ;;
  *) echo "upgrade-rpm: unsupported arch" >&2; exit 1 ;;
esac

cd ~/bin
zip_file_name="$os-$arch.zip"
curl --location -O "https://rpm.reillywood.com/$zip_file_name"
unzip -o "$zip_file_name"
